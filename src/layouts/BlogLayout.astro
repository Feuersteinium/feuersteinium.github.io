---
const { frontmatter } = Astro.props;
import '../styles/global.css'
import '../styles/blog.css'
import Header from '../components/header.astro'
import Footer from '../components/footer.astro'
import Umami from '../components/umami.astro'
---
<head>
    <Umami />
</head>
<body>
    <Header />
    <section>
        <h2 id="blog-main-headline">{frontmatter.title}</h2>
        <hr>
        <img id="blog-title-img" src="https://unsplash.it/1920/1080">
        <div class="blog-userinfo">
            <p>Autor: {frontmatter.author}</p>
            <p>Veröffentlicht am: {frontmatter.pubDate}</p>
            <p>{frontmatter.status}</p>
        </div>
        <div class="blog-textbox">
            <p id="blog-description">{frontmatter.description}</p>
            <slot />
        </div>  
    </section>
    <Footer />
</body>